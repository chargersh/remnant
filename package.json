{
  "name": "remnant",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "sonner": "^2.0.7",
      "convex": "^1.33.1",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "check": "bun run typecheck && bun run lint",
    "auth:collector": "bun run --cwd apps/collector auth",
    "sync:dialogs": "bun run --cwd apps/collector sync-dialogs",
    "dev:collector": "turbo -F collector dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @remnant/backend dev",
    "dev:setup": "turbo -F @remnant/backend dev:setup"
  },
  "dependencies": {
    "@remnant/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@effect/language-service": "^0.86.2",
    "@remnant/config": "workspace:*",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.1"
}
